# TikZ AI — Environment Variables Example
# Copy this file to .env and fill in your values
# cp .env.example .env

# ── IBM Cloud API Key ──────────────────────────────────────────────────────────
# Get it: cloud.ibm.com → Manage → IAM → API Keys → Create
IBM_API_KEY=your-ibm-cloud-api-key-here

# ── IBM Watson Machine Learning ────────────────────────────────────────────────
# WML endpoint for your region
WML_URL=https://eu-de.ml.cloud.ibm.com

# Watson Studio Project UUID (NOT your account ID)
# Get it: dataplatform.cloud.ibm.com → your project → Manage tab → Project ID
WML_PROJECT_ID=xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx

# ── watsonx Orchestrate ────────────────────────────────────────────────────────
# Your Orchestrate service instance GUID
# Get it: cloud.ibm.com → Resource List → watsonx Orchestrate → GUID
ORCHESTRATE_INSTANCE_ID=xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx

# Your Agent ID (from the agent URL in the Orchestrate console)
# Get it: watsonx Orchestrate → open your agent → copy UUID from browser URL
AGENT_ID=xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx

# Orchestrate API host (eu-de region)
ORCHESTRATE_HOST=api.eu-de.watson-orchestrate.cloud.ibm.com

# ── Server ─────────────────────────────────────────────────────────────────────
PORT=3000
IBM_REGION=eu-de
IBM_RESOURCE_GROUP=Default
APP_NAME=tikzai
